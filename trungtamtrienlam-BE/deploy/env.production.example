# Copy this file to deploy/.env.production and replace every CHANGE_ME value.
COMPOSE_PROJECT_NAME=trungtamtrienlam-backend
BACKEND_ENV_FILE=deploy/.env.production
BACKEND_IMAGE=trungtamtrienlam-backend:local
DJANGO_SETTINGS_MODULE=config.settings.production

SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_VALUE
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://localhost
FRONTEND_URL=http://localhost:3000

ACCESS_TOKEN_LIFETIME_DAYS=1
REFRESH_TOKEN_LIFETIME_DAYS=30

DB_NAME=trungtamtrienlam
DB_USER=trungtamtrienlam
DB_PASSWORD=CHANGE_ME_TO_A_STRONG_DATABASE_PASSWORD
DB_HOST=postgres
DB_PORT=5432

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

APP_PORT=8000
HTTP_PORT=80
WEB_CONCURRENCY=2
CELERY_CONCURRENCY=2

WAIT_FOR_DATABASE=true
DB_WAIT_MAX_ATTEMPTS=30
DB_WAIT_RETRY_SECONDS=2
RUN_MIGRATIONS=false
RUN_COLLECTSTATIC=false

# Keep these disabled for plain HTTP. Enable only after HTTPS is configured
# at the trusted reverse proxy/load balancer.
SECURE_SSL_REDIRECT=false
SESSION_COOKIE_SECURE=false
CSRF_COOKIE_SECURE=false
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=false
SECURE_HSTS_PRELOAD=false
USE_X_FORWARDED_HOST=false
TRUST_X_FORWARDED_PROTO=false

# Preserve the current integrations by supplying the real deployment values.
CDN_BASE_URL=https://trungtambaoton-cloud.hongvan.net
CDN_API_URL=https://trungtambaoton-cloud.hongvan.net/api
ONLYOFFICE_SERVER_URL=https://onlyoffice.hongvan.net
ONLYOFFICE_JWT_TOKEN=
WEB_PUSH_PUBLIC_KEY=
WEB_PUSH_PRIVATE_KEY=

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=
