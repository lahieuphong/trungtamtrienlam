name: 3d-market-backend-dev

networks:
  proxy:
    driver: bridge

services:
  app:
    build:
      context: .
      args:
        BUILD_ENV: dev
      target: container-dev
      network: host
    # Tránh mount .venv Windows → Linux: poetry run tạo lại .venv trống → không có Django.
    # Khớp Dockerfile (poetry config virtualenvs.create false): dùng Python system trong image.
    environment:
      POETRY_VIRTUALENVS_CREATE: "false"
      POETRY_VIRTUALENVS_IN_PROJECT: "false"
    volumes:
      - ./app:/app
      - ./.env.local:/app/.env:ro
      - /mnt/docker-nfs/3d-market-media:/media
    depends_on:
      redis:
          condition: service_healthy
    command: ["python", "manage.py", "runserver", "0.0.0.0:8002"]
    ports:
      - "8002:8002"
    networks:
      - proxy
  redis:
    image: redis:7-alpine
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 5s
      timeout: 3s
      retries: 5
    networks:
      - proxy
